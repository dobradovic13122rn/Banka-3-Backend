meta {
  name: Password Reset Request
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/password-reset/request
  body: json
  auth: none
}

body:json {
  {
    "email": "{{clientEmail}}"
  }
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("has message", function() {
    expect(res.body.message).to.be.a("string");
  });
}
