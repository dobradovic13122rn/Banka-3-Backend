meta {
  name: Update Account Name
  type: http
  seq: 6
}

patch {
  url: {{baseUrl}}/api/accounts/{{testAccountNumber}}/name
  body: json
  auth: none
}

headers {
  Authorization: Bearer {{accessToken}}
}

body:json {
  {
    "name": "My Main RSD Account"
  }
}

tests {
  test("status 200", function() {
    expect(res.status).to.equal(200);
  });
  test("success message", function() {
    expect(res.body.message).to.equal("Name updated");
  });
}
